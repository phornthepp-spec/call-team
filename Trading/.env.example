# ──────────────────────────────────────────────────────────────────
# XAUUSD Full-Auto Trading System — Environment Configuration
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.

# ── Application ──────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/trading
DATABASE_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Security ─────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── MetaTrader 5 ─────────────────────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=ACCM-Live
MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_TERMINAL_DATA_PATH=
MT5_SIMULATION_MODE=true

# ── Broker ───────────────────────────────────────────────────────
BROKER_NAME=ACCM
BROKER_DOMAIN=accm.global

# ── Trading Settings (override via settings.json for full config)
POLICY_MODE=strict
PRIMARY_SYMBOL=XAUUSD
PRIMARY_TIMEFRAME=M15

# ── Auto-Trade ───────────────────────────────────────────────────
AUTO_TRADE_INTERVAL_SECONDS=60
AUTO_TRADE_MAGIC_NUMBER=999999
COMMENT_PREFIX=7H-AUTO
