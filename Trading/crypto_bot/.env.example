# ──────────────────────────────────────────────────────────────────
# Crypto Auto Trading Bot — Environment Configuration
# ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control.

# ── Exchange API Keys ────────────────────────────────────────────
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your-api-key-here
EXCHANGE_API_SECRET=your-api-secret-here

# ── Trading Mode ─────────────────────────────────────────────────
# IMPORTANT: Set to false ONLY when ready for real trading
DRY_RUN=true

# ── Trading Pair ─────────────────────────────────────────────────
SYMBOL=BTC/USDT
TIMEFRAME=15m

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
